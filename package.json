{
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "cypress": "^14.5.4",
    "esbuild": "^0.27.4",
    "mocha": "^11.7.6",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/**/*.js",
      "cypress/support/step_definitions/**/*.js"
    ]
  },
  "scripts": {
    "clean:reports": "rm -rf cypress/reports || true",
    "cy:run": "npx cypress run",
    "merge:reports": "npx mochawesome-merge cypress/reports/*.json > cypress/reports/merged-report.json",
    "generate:html": "npx marge cypress/reports/merged-report.json --reportDir cypress/reports --inline",
    "report": "npm run clean:reports && npm run cy:run || npm run merge:reports && npm run generate:html"
  }
}